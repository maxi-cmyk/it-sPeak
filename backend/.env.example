# Copy to `.env` and fill in. All keys are optional except the LLM key for the
# provider you choose. Prefix is ITSPEAK_.

# --- Celery / Redis ---
ITSPEAK_REDIS_URL=redis://localhost:6379/0

# --- Frame sampling ---
ITSPEAK_SAMPLE_FPS=5.0
ITSPEAK_GATE_MAX_FPS=1.0
ITSPEAK_GATE_MAX_FRAMES=24
ITSPEAK_MAX_FRAME_WIDTH=640
# On Windows, point these at the ffmpeg/ffprobe .exe if not on PATH:
# ITSPEAK_FFMPEG_BIN=C:\ffmpeg\bin\ffmpeg.exe
# ITSPEAK_FFPROBE_BIN=C:\ffmpeg\bin\ffprobe.exe

# --- MediaPipe confidence / degradation ---
ITSPEAK_MIN_DETECTION_CONFIDENCE=0.5
ITSPEAK_MIN_TRACKING_CONFIDENCE=0.5
ITSPEAK_MIN_VALID_FRAME_RATIO=0.30

# --- OpenAI ---
ITSPEAK_OPENAI_API_KEY=
ITSPEAK_COACHING_MODEL=gpt-4o-mini
ITSPEAK_TRANSCRIPTION_MODEL=whisper-1
ITSPEAK_LLM_TEMPERATURE=0.3
ITSPEAK_LLM_MAX_OUTPUT_TOKENS=2048

# --- API / uploads ---
ITSPEAK_FRONTEND_ORIGIN=http://localhost:3000
ITSPEAK_ARTIFACT_DIR=/tmp/itspeak-sessions
ITSPEAK_MAX_UPLOAD_BYTES=262144000
ITSPEAK_ARTIFACT_RETENTION_SECONDS=86400
ITSPEAK_CLEANUP_INTERVAL_SECONDS=3600

# --- Quality thresholds (raw measurements are retained in each gate report) ---
ITSPEAK_GATE_LUMINANCE_LOW=45
ITSPEAK_GATE_LUMINANCE_HIGH=220
ITSPEAK_GATE_CONTRAST_MIN=20
ITSPEAK_GATE_BLUR_VARIANCE_MIN=45
ITSPEAK_GATE_FACE_PIXELS_MIN=200
ITSPEAK_GATE_FACE_PRESENCE_MIN=0.70
ITSPEAK_GATE_AUDIO_RMS_MIN_DBFS=-35
ITSPEAK_GATE_AUDIO_PEAK_MAX_DBFS=-1
ITSPEAK_GATE_SILENCE_MAX_RATIO=0.40
